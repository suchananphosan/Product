<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SABINA</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@200;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Sarabun', sans-serif;
            background-color: #ffffff;
        }

        /* ===== NAVBAR ===== */
        .navbar-sabina {
            border-bottom: 1px solid #eee;
            padding: 1.5rem 0;
        }

        /* ===== LOGO ===== */
        .sabina-logo-img {
            height: 28px;
            transition: opacity 0.2s ease;
        }

        .sabina-logo-img:hover {
            opacity: 0.7;
        }

        /* ===== LAYOUT ===== */
        .nav-column {
            flex: 1;
            display: flex;
            align-items: center;
        }

        .main-container {
            padding-top: 30px;
        }

        /* ===== FOOTER ===== */
        .site-footer {
            font-size: 12px;
            letter-spacing: 1px;
            background-color: #fff;
        }
    </style>
</head>

<body>
    <!-- ================= NAVBAR ================= -->
<header>
    <nav class="navbar navbar-sabina bg-white">
        <div class="container-fluid px-lg-5 d-flex justify-content-between align-items-center">

            <!-- LEFT -->
            <div class="nav-column justify-content-start d-none d-lg-flex">
                <img src="https://flagcdn.com/w20/th.png" width="20" class="me-2" alt="Thai Flag">
                <span style="font-size: 12px; color: #666; letter-spacing: 1px;">THAI</span>
            </div>

            <!-- CENTER (LOGO) -->
            <div class="nav-column justify-content-center">
                <a asp-controller="Productmasters" asp-action="Index">
                    <img src="@Url.Content("~/images/sabina-logo.png")"
                         alt="Sabina Logo"
                         style="height: 50px;">
                </a>
            </div>

            <!-- RIGHT -->
            <div class="nav-column justify-content-end">
                <div style="width: 50px;" class="d-lg-none"></div>
            </div>

        </div>
    </nav>
</header>

    <!-- ================= CONTENT ================= -->
    <div class="container main-container">
        <main role="main" class="pb-5">

            @RenderBody()
        </main>
    </div>


    <!-- ================= SCRIPTS ================= -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>